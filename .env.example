APP_NAME=GraphRCA API
APP_ENV=development

# Existing Neo4j instance
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=neo4j

# Existing local llama.cpp server
LLAMA_BASE_URL=http://127.0.0.1:8080/v1/chat/completions
LLAMA_TIMEOUT_SECONDS=300

# Retrieval / UI behavior
RETRIEVAL_DEBUG_ENABLED=false
UI_BACKEND_BASE_URL=http://127.0.0.1:8000
UI_INVESTIGATE_ENDPOINT=/investigate
UI_REQUEST_TIMEOUT_SECONDS=300
